# 智能问数（Intelligent Data Query）环境变量
LLM_API_KEY=sk-your-deepseek-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
# true 时使用确定性的本地 Demo 查询计划，不依赖 LLM API Key
DEMO_MODE=false
# 留空表示本地 Demo 不启用 API Key；部署时建议设置随机长字符串
API_KEY=
AUTH_ENABLED=false
AUTH_USERNAME=demo
AUTH_PASSWORD=change-me
AUTH_SECRET=change-me-in-production
AUTH_TOKEN_TTL_SECONDS=3600
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
LLM_TIMEOUT_SECONDS=30
REQUEST_TIMEOUT_SECONDS=45
DB_CONNECT_TIMEOUT=3
DB_READ_TIMEOUT=20
DB_WRITE_TIMEOUT=20

# MySQL ai_query
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=aiquery_readonly
DB_PASSWORD=your-password
DB_NAME=ai_query

CHART_OUTPUT_DIR=./output/charts
PORT=8000
APP_ENV=demo
SESSION_TTL_SECONDS=3600
MAX_SESSIONS=1000
SESSION_BACKEND=memory
QUERY_MAX_ROWS=500
SENSITIVE_FIELDS=password,phone,email,id_card,token
LLM_MAX_RESPONSE_CHARS=20000
CHART_RETENTION_SECONDS=86400
CHART_MAX_FILES=200
